@model List<Northwind.Customers.Web.Models.CustomerRowViewModel>

@if (!Model.Any())
{
	<tr>
		<td colspan="3" class="py-5 text-center">
			<i class="bi bi-search display-4 text-muted d-block mb-3"></i>
			<p class="text-muted">No customers found.</p>
		</td>
	</tr>
}
else
{
	foreach (var customer in Model)
	{
		<tr>
			<td class="ps-4">
				<span class="fw-bold text-navy">@customer.CustomerName</span>
				<small class="text-muted d-block" style="font-size: 0.7rem;">REF: @customer.CustomerId</small>
			</td>
			<td class="text-center">
				<span class="badge bg-blue-soft text-primary rounded-pill px-3">@customer.OrderCount</span>
			</td>
			<td class="text-end pe-4">
				<a asp-action="Details" asp-route-id="@customer.CustomerId" class="btn btn-sm btn-outline-primary px-3">
					<i class="bi bi-eye me-1"></i>View History
				</a>
			</td>
		</tr>
	}
}